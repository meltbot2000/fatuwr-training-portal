# ─── Database ─────────────────────────────────────────────────────────────────
# MySQL connection string. The project uses MySQL (drizzle-orm/mysql2), NOT SQLite.
# Format: mysql://user:password@host:3306/dbname
DATABASE_URL=mysql://user:password@localhost:3306/fatuwr

# ─── Auth / Session ───────────────────────────────────────────────────────────
# Secret used to sign JWTs / session cookies. Use a long, random string.
JWT_SECRET=change-me-to-a-long-random-string

# ─── OAuth ────────────────────────────────────────────────────────────────────
# URL of the OAuth server used for sign-in
OAUTH_SERVER_URL=https://your-oauth-server.example.com

# ─── App Identity ─────────────────────────────────────────────────────────────
# Application ID exposed to the frontend via Vite
VITE_APP_ID=your-app-id

# OpenID of the owner/admin account — this account gets the admin role automatically
OWNER_OPEN_ID=your-open-id

# ─── Built-in Forge / Notification API (optional) ─────────────────────────────
# Legacy notification endpoint (Manus-specific). Not required if using Resend.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Email — Gmail SMTP (recommended until domain is verified) ────────────────
# Use a Gmail account + App Password to send OTP emails to any recipient
# with no domain verification required.
# Steps: myaccount.google.com → Security → 2-Step Verification → App passwords
# Create an app password for "Mail" and paste it below.
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Email — Resend (use once your domain is verified) ────────────────────────
# Sign up at https://resend.com · Verify your domain at resend.com/domains.
# Note: onboarding@resend.dev only sends to the Resend account owner's email.
# You must use a verified domain (e.g. noreply@yourdomain.com) to reach all users.
# Gmail SMTP is tried first; Resend is used as a fallback when GMAIL_USER is not set.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_API_FROM=noreply@yourdomain.com

# ─── Google Apps Script ───────────────────────────────────────────────────────
# URL of the deployed Google Apps Script web app
GOOGLE_APPS_SCRIPT_URL=
# Shared secret sent in every GAS request body. Set the same value in GAS as appsScriptSecret.
APPS_SCRIPT_SECRET=change-me-to-a-random-secret

# ─── Google Sheets API (service account) ──────────────────────────────────────
# Paste the entire contents of your service account JSON key file as a single line.
# Download from: Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON
# Then share the Google Sheet with the service account email address.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
